# Vercel Environment Variables
# Inhe Vercel dashboard mein add karna hoga

# MongoDB Atlas Connection String
# MongoDB Atlas pe free cluster banayein: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/cloud-erp

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT Expiry
JWT_EXPIRE=7d

# Node Environment
NODE_ENV=production
